{
  "app": "npx ts-node --prefer-ts-exts lib/Shipment-stack.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.d.ts", "**/*.js", "tsconfig.json", "package*.json", "node_modules", "dist"]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/aws-elasticloadbalancingv2:standardTargetGroupHealthCheck": true,
    "@aws-cdk/aws-rds:databaseProxyUniqueResourceName": true
  }
}
