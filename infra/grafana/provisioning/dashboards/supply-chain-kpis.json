{
  "title": "Supply Chain KPIs",
  "tags": ["supply-chain", "logistics"],
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "id": 1, "title": "Shipments by Status", "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "postgres-logistics" },
        "format": "table",
        "rawSql": "SELECT status, count(*) AS count FROM shipments GROUP BY status ORDER BY count DESC",
        "refId": "A"
      }]
    },
    {
      "id": 2, "title": "Shipments (24h)", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "datasource": { "type": "postgres", "uid": "postgres-logistics" }, "rawSql": "SELECT count(*) FROM shipments WHERE created_at > now() - interval '24 hours'", "refId": "A" }]
    },
    {
      "id": 3, "title": "SLA Compliance %", "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "datasource": { "type": "postgres", "uid": "postgres-logistics" }, "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE delivered_at <= estimated_delivery_at) / NULLIF(COUNT(*), 0), 1) FROM shipments WHERE status = 'DELIVERED'", "refId": "A" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "thresholds": { "steps": [{"color": "red", "value": 80}, {"color": "yellow", "value": 90}, {"color": "green", "value": 95}] } } }
    },
    {
      "id": 4, "title": "Avg Delivery (hrs)", "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "datasource": { "type": "postgres", "uid": "postgres-logistics" }, "rawSql": "SELECT ROUND(AVG(EXTRACT(EPOCH FROM (delivered_at - created_at)) / 3600), 1) FROM shipments WHERE status = 'DELIVERED'", "refId": "A" }]
    },
    {
      "id": 5, "title": "Shipments by Priority", "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [{ "datasource": { "type": "postgres", "uid": "postgres-logistics" }, "rawSql": "SELECT priority, count(*) FROM shipments GROUP BY priority", "refId": "A" }]
    },
    {
      "id": 6, "title": "Active Shipments by Origin", "type": "barchart",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "targets": [{ "datasource": { "type": "postgres", "uid": "postgres-logistics" }, "rawSql": "SELECT w.name, count(s.id) FROM shipments s JOIN warehouses w ON s.origin_warehouse_id = w.id WHERE s.status NOT IN ('DELIVERED', 'CANCELLED') GROUP BY w.name ORDER BY count DESC", "refId": "A" }]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
